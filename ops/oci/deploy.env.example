# Non-secret deployment settings for ops/oci/deploy-image.sh.
# Copy this file on the OCI host and fill environment-specific values there.

# Registry image reference. Use tag for pull, digest for stable activation when available.
GMM_IMAGE="ghcr.io/OWNER/REPOSITORY/gmail-monitor:manual"

# Existing runtime inputs on the OCI host.
GMM_ENV_FILE="/opt/gmm_project/Gmail-Monitor/.env"
GMM_RUNTIME_DIR="/opt/gmm_runtime"

# Host-side deploy state. This file stores image references and check status only.
GMM_DEPLOY_STATE="/opt/gmm_deploy/deploy-state.env"

# Existing host port contract used by nginx.
GMM_HOST_PORT="127.0.0.1:8080:8080"

# Optional: systemd environment file consumed by a service drop-in or ExecStart wrapper.
GMM_SYSTEMD_ENV="/etc/gmm/deploy-image.env"
